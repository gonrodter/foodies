# Mapbox — get a free token at https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=

# Supabase — from your project settings (https://app.supabase.com)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional: service-role key for server API routes (bypasses RLS). Never expose client-side.
SUPABASE_SERVICE_ROLE_KEY=

# Geoapify Places — server-only, get a free key at https://myprojects.geoapify.com/
GEOAPIFY_API_KEY=
